{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python static server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "npx serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "8080"],
      "port": 8080
    },
    {
      "name": "npx live-server (auto-reload)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=8080"],
      "port": 8080
    }
  ]
}
